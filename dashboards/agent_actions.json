{
  "id": null,
  "uid": "nhi-agent-actions",
  "title": "NHI-Sentinel — Agent Actions",
  "description": "Real-time view of agent action rates, deny rates, and approval queue depth",
  "tags": ["nhi-sentinel", "agents"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Action Rate (all agents)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(nhi_agent_actions_total[1m])",
          "legendFormat": "{{agent_type}} — {{decision}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Deny Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * rate(nhi_agent_actions_total{decision=\"DENY\"}[5m]) / rate(nhi_agent_actions_total[5m])",
          "legendFormat": "{{agent_type}} deny rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Approval Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_approval_queue_depth",
          "legendFormat": "Pending approvals"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Token Issuances (rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(nhi_token_issuances_total[5m])",
          "legendFormat": "tokens/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 5,
      "title": "Actions by Agent Type (last hour)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (agent_type) (increase(nhi_agent_actions_total[1h]))",
          "legendFormat": "{{agent_type}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent Agent Activity (logs)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=\"nhi-pep\"} | json | line_format \"{{.level}} | {{.agent_id}} | {{.action}} | {{.effect}}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending"
      }
    }
  ]
}
