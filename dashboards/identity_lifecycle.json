{
  "id": null,
  "uid": "nhi-identity",
  "title": "NHI-Sentinel — Identity Lifecycle",
  "description": "NHI inventory, state transitions, token issuance, and expiry alerts",
  "tags": ["nhi-sentinel", "identity"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active NHIs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_identities_by_state{state=\"ACTIVE\"}",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } }
      }
    },
    {
      "id": 2,
      "title": "Suspended NHIs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_identities_by_state{state=\"SUSPENDED\"}",
          "legendFormat": "Suspended"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Expiring Soon (< 7 days)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_identities_by_state{state=\"EXPIRING\"}",
          "legendFormat": "Expiring"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "NHIs by State (distribution)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_identities_by_state",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Token Issuance Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(nhi_token_issuances_total[5m])",
          "legendFormat": "tokens/sec"
        },
        {
          "expr": "rate(nhi_token_rejections_total[5m])",
          "legendFormat": "rejections/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Identity State Transitions (logs)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=\"nhi-identity\"} | json"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
