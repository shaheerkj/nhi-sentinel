{
  "id": null,
  "uid": "nhi-anomaly",
  "title": "NHI-Sentinel — Anomaly Detection",
  "description": "Per-agent anomaly scores, burst detection, and identity suspension events",
  "tags": ["nhi-sentinel", "anomaly", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Anomaly Score per Agent",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_anomaly_score",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "orange", "value": 0.85 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Critical Anomalies (score > 0.95)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(nhi_anomaly_score > 0.95) or vector(0)",
          "legendFormat": "Agents in critical state"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Suspended Identities",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "nhi_suspended_identities_total",
          "legendFormat": "Suspensions (all time)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Burst Events Detected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "increase(nhi_burst_detections_total[1h])",
          "legendFormat": "Burst events (last hour)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Events Scored (rate)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(nhi_anomaly_events_scored_total[1m])",
          "legendFormat": "Events scored/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Anomaly Alerts (logs)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=\"nhi-anomaly\"} |= \"anomal\" | json"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
