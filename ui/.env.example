# Service base URLs. The dev server proxies /api/* to these via next.config.js
# so the browser doesn't hit them directly (avoids CORS during local dev).
NEXT_PUBLIC_AUDIT_URL=http://localhost:8001
NEXT_PUBLIC_IDENTITY_URL=http://localhost:8002
NEXT_PUBLIC_ANOMALY_URL=http://localhost:8000
NEXT_PUBLIC_APPROVAL_URL=http://localhost:8003
